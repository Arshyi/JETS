# Public production origin used for metadata and Supabase redirect planning.
# Example: https://jets.example.com
NEXT_PUBLIC_SITE_URL=

# Optional public preview host fallback when NEXT_PUBLIC_SITE_URL is not set.
# Example: jets-git-main-your-team.vercel.app
NEXT_PUBLIC_VERCEL_URL=

# Public Supabase browser/server anon configuration.
# Example: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Example: eyJ...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret server-only key for admin ingestion dry-run persistence.
# Example: eyJ...
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated admin allowlist for /admin/ingestion.
# Example: admin@example.com
JETS_ADMIN_EMAILS=
